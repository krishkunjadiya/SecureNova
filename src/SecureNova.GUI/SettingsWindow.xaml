<Window x:Class="SecureNova.GUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureNova Settings" Height="450" Width="600"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <GroupBox Header="Notification Settings">
            <StackPanel Margin="10">
                <CheckBox Content="Enable Email Notifications" Margin="0,5"/>
                <TextBox Text="email@example.com" Margin="20,5,0,5"/>
                
                <CheckBox Content="Enable Telegram Notifications" Margin="0,10,0,5"/>
                <TextBox Text="Bot Token" Margin="20,5,0,5"/>
                <TextBox Text="Chat ID" Margin="20,5,0,5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Scan Settings" Margin="0,20,0,0">
            <StackPanel Margin="10">
                <CheckBox Content="Scan System Files" IsChecked="True" Margin="0,5"/>
                <CheckBox Content="Scan User Files" IsChecked="True" Margin="0,5"/>
                <CheckBox Content="Scan Network Drives" IsChecked="False" Margin="0,5"/>
                <CheckBox Content="Deep Process Analysis" IsChecked="True" Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Save" Width="100" Margin="0,0,10,0" Click="OnSaveClick"/>
            <Button Content="Cancel" Width="100" Click="OnCancelClick"/>
        </StackPanel>
    </StackPanel>
</Window> 