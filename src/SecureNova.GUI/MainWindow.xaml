<Window x:Class="SecureNova.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureNova Security Monitor" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnScan" Content="Start Scan" Width="100" Height="30" Click="OnScanClick"/>
            <Button Content="Export Log" Width="100" Height="30" Margin="10,0" Click="OnExportLogClick"/>
            <Button Content="Settings" Width="100" Height="30" Click="OnSettingsClick"/>
            <TextBlock x:Name="txtStatus" Text="Status: Ready" VerticalAlignment="Center" Margin="20,0"/>
        </StackPanel>

        <!-- Alert Summary -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Total Alerts: " VerticalAlignment="Center"/>
            <TextBlock x:Name="txtTotalAlerts" Text="0" VerticalAlignment="Center" Margin="5,0,20,0"/>
            <TextBlock Text="High Severity: " VerticalAlignment="Center"/>
            <TextBlock x:Name="txtHighSeverity" Text="0" VerticalAlignment="Center" Margin="5,0"/>
        </StackPanel>

        <!-- Main Content -->
        <TabControl Grid.Row="2">
            <!-- Live Activity Stream -->
            <TabItem Header="Live Activity">
                <ListView x:Name="lvActivityStream">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="150"/>
                            <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="120"/>
                            <GridViewColumn Header="Severity" DisplayMemberBinding="{Binding Severity}" Width="80"/>
                            <GridViewColumn Header="Details" DisplayMemberBinding="{Binding Details}" Width="400"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <!-- File Changes -->
            <TabItem Header="File Changes">
                <ListView x:Name="lvFileChanges">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="150"/>
                            <GridViewColumn Header="File" DisplayMemberBinding="{Binding FileName}" Width="200"/>
                            <GridViewColumn Header="Action" DisplayMemberBinding="{Binding Action}" Width="100"/>
                            <GridViewColumn Header="Path" DisplayMemberBinding="{Binding Path}" Width="300"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <!-- Process Monitor -->
            <TabItem Header="Process Risk Map">
                <ListView x:Name="lvProcesses">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150"/>
                            <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Id}" Width="80"/>
                            <GridViewColumn Header="Risk Level" DisplayMemberBinding="{Binding RiskLevel}" Width="100"/>
                            <GridViewColumn Header="Location" DisplayMemberBinding="{Binding Path}" Width="300"/>
                            <GridViewColumn Header="Signature" DisplayMemberBinding="{Binding SignatureStatus}" Width="120"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>
    </Grid>
</Window> 